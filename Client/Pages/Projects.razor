@page "/projects"
@using SkillSnap.Shared.Models
@using SkillSnap.Client.Services
@inject ProjectService ProjectService

<h3>Projects</h3>

@if (projects == null)
{
  <p>Loading projects...</p>
}
else if (!projects.Any())
{
  <p>No projects found.</p>
}
else
{
  <ul>
    @foreach (Project project in projects)
    {
      <li>
        <strong>@project.Title</strong><br />
        @project.Description
      </li>
    }
  </ul>
}

<button @onclick="AddSampleProject">Add Sample Project</button>

@code {
  private List<Project>? projects;

  protected override async Task OnInitializedAsync()
  {
    projects = await ProjectService.GetProjectsAsync();
  }

  private async Task AddSampleProject()
  {
    Project newProject = new Project
    {
      Title = "New Blazor Project",
      Description = "Created from the Blazor client.",
      ImageUrl = "https://via.placeholder.com/300",
      PortfolioUserId = 1
    };

    Project? createdProject = await ProjectService.AddProjectAsync(newProject);

    if (createdProject != null)
    {
      projects ??= new List<Project>();
      projects.Add(createdProject);
    }
  }
}