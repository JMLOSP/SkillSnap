@SkillSnap_Api_HostAddress = http://localhost:5134

### ========================================
### AUTH
### ========================================

### Register user
POST {{SkillSnap_Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "yo@yo.com",
  "password": "a123456789"
}

###

### Login
# @name login
POST {{SkillSnap_Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "yo@yo.com",
  "password": "a123456789"
}

###

# Extract token from login response
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..3I0Q3zcvDNM2RYKxdanLGsQnSN8w47v5u-rtogwGTJk

### ========================================
### PROJECTS
### ========================================

### Get all projects (PUBLIC)
GET {{SkillSnap_Api_HostAddress}}/api/projects
Accept: application/json

###

### Create project (AUTH REQUIRED)
POST {{SkillSnap_Api_HostAddress}}/api/projects
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Portfolio Website",
  "description": "A personal portfolio built with Blazor.",
  "imageUrl": "https://via.placeholder.com/300",
  "portfolioUserId": 1
}

###

### Update project (AUTH REQUIRED)
PUT {{SkillSnap_Api_HostAddress}}/api/projects/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "id": 1,
  "title": "Updated Project",
  "description": "Updated description",
  "imageUrl": "https://via.placeholder.com/300",
  "portfolioUserId": 1
}

###

### Delete project (ADMIN ONLY)
DELETE {{SkillSnap_Api_HostAddress}}/api/projects/1
Authorization: Bearer {{token}}

###

### ========================================
### SKILLS
### ========================================

### Get all skills (PUBLIC)
GET {{SkillSnap_Api_HostAddress}}/api/skills
Accept: application/json

###

### Create skill (AUTH REQUIRED)
POST {{SkillSnap_Api_HostAddress}}/api/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Blazor",
  "level": "4",
  "portfolioUserId": 1
}

###

### Update skill (AUTH REQUIRED)
PUT {{SkillSnap_Api_HostAddress}}/api/skills/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "id": 1,
  "name": "Blazor Updated",
  "level": "5",
  "portfolioUserId": 1
}

###

### Delete skill (ADMIN ONLY)
DELETE {{SkillSnap_Api_HostAddress}}/api/skills/1
Authorization: Bearer {{token}}